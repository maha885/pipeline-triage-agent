# Azure AI Foundry serverless model endpoint (Phi-4, etc.)
# Found in Foundry portal -> Model deployments -> your deployment -> endpoint
FOUNDRY_ENDPOINT=https://your-deployment.region.models.ai.azure.com
FOUNDRY_API_KEY=your-foundry-api-key
FOUNDRY_MODEL_NAME=Phi-4

# Optional: switch to Azure OpenAI later by setting these instead
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Which backend to use: "foundry" or "azure_openai"
MODEL_BACKEND=foundry

# Teams incoming webhook URL (Workflows connector)
TEAMS_WEBHOOK_URL=
